# Bharat Saarthi AI — Backend Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required for AI chat & vision features)
GEMINI_API_KEY=your_gemini_api_key_here

# Database (Optional — defaults to local SQLite if left empty)
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=4000

# JWT Secret (Required for Google OAuth session signing)
JWT_SECRET=your_random_jwt_secret_here
